# Wrapper-level ignores. Subfolder .gitignores (front-end/.gitignore,
# backend/.gitignore) cover their own files; this file only handles things
# that live at the monorepo root.

# Tool/agent state — environment-specific, not source.
.claude/
.figma-cache/

# Logs and OS artifacts
*.log
.DS_Store

# Backup / scratch
*.bak
*.tmp
