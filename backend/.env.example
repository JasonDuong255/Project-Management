# See README.md "Environment variables" for the full table + deployment guidance.
# Copy this file to .env and fill in real values. NEVER commit .env (gitignored).

# ─── Express server ────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated origins allowed by CORS. In prod: your FE domain(s).
CORS_ORIGIN=http://localhost:5173

# ─── Supabase project ──────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>

# Optional. When set, JWT verification is local (HS256) — fast.
# When empty, the middleware falls back to supabase.auth.getUser(token) per
# request — slower (one network call). Strongly recommended in production.
SUPABASE_JWT_SECRET=

# ─── Postgres connection ───────────────────────────────────────────────────
# IMPORTANT: use the SESSION-MODE pooler URL (port 5432), NOT pgbouncer
# transaction mode (6543). Prisma's interactive transactions break on
# transaction-mode pgbouncer because each query gets a different physical
# connection.
DATABASE_URL=postgresql://postgres.<ref>:<pwd>@aws-…pooler.supabase.com:5432/postgres?connection_limit=10&pool_timeout=30
DIRECT_URL=postgresql://postgres.<ref>:<pwd>@aws-…pooler.supabase.com:5432/postgres

# ─── Email (notifications for close-flow approvals) ───────────────────────
# 'console' = print to stdout (dev). 'smtp' = send via nodemailer (prod).
EMAIL_TRANSPORT=console
# Required only when EMAIL_TRANSPORT=smtp:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=…
# SMTP_PASS=…
# SMTP_FROM="QLDA <noreply@qlda.example.com>"

# ─── Scheduler (auto-health + deadline alerts) ────────────────────────────
# Set 'true' on EXACTLY ONE backend instance in production to avoid duplicate
# alerts. Leave unset in dev to avoid cron noise.
RUN_SCHEDULER=
