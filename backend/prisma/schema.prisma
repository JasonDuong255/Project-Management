// QLDA Project Management — domain schema.
// Mirror of Project-Management/src/types/index.ts.
// Strategy: flat tables for queryable arrays; JSONB for opaque nested structs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  PMO
  ADMIN_HC
  PM
  DELIVERY_MEMBER
}

enum ProjectStatus {
  ACTIVE  // Đang triển khai
  PAUSED  // Tạm đóng
  CLOSED  // Đóng
}

enum HealthStatus {
  STABLE        // Ổn định — all tasks on time
  NEEDS_REVIEW  // Cần xem xét — at least one task within 4 days of deadline, not done
  AT_RISK       // Có rủi ro — at least one task past deadline, not done
}

enum ProjectType {
  PRELIMINARY  // Tiền khả thi
  FEASIBILITY  // Khả thi
  CONTRACT     // Có HĐ
  INTERNAL     // Nội bộ
}

enum FunctionalTitle {
  NORMAL
  KSV   // Kiểm soát viên — quality control / approver in DBCL dept
  // (BA 14/05/2026: TCNL was removed — the second-stage approver is now
  // TCHC, which is the regular ADMIN_HC role and needs no overlay.)
}

enum PlanTaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
  NEEDS_REPLAN
}

enum WorkType {
  PRELIMINARY
  SUBTASK
  MILESTONE
}

enum DelayRaiseStatus {
  OPEN
  ACKNOWLEDGED
  REPLANNED
}

// v3.12 BA #7 (19/05/2026): worklog cần duyệt bởi PM/điều phối trước khi
// cộng vào task.actualHours.
enum WorklogStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum RiskStatus {
  OPEN
  WATCHING
  MITIGATED
}

enum ActivityLogAction {
  PROJECT_INFO_UPDATED
  PERSONNEL_UPDATED
  DOCUMENT_ADDED
  DOCUMENT_DELETED
  TASK_CREATED
  SUBTASK_CREATED
  TASK_UPDATED
  SUBTASK_UPDATED
  TASK_DELETED
  SUBTASK_DELETED
  TASK_HOURS_CHANGED
  SUBTASK_HOURS_CHANGED
  WORKLOG_ADDED
  PROJECT_CLOSED
  PROJECT_REOPENED
  // v3.1: close-workflow + pause flow precursors. Most consumers land in v3.2.
  PROJECT_PAUSED
  PROJECT_REOPENED_FROM_PAUSE
  CLOSE_REQUESTED
  CLOSE_APPROVED_KSV
  CLOSE_REJECTED_KSV
  CLOSE_CONFIRMED_TCHC
  CLOSE_REJECTED_TCHC
  // v3.3: risk + personnel + document granular history.
  RISK_CREATED
  RISK_UPDATED
  RISK_DELETED
  PERSONNEL_ADDED
  PERSONNEL_REMOVED
  DOCUMENT_UPDATED
  ALLOCATION_UPDATED
  // v3.12 BA #7 (19/05/2026): worklog approval workflow.
  WORKLOG_APPROVED
  WORKLOG_REJECTED
}

enum ExternalPersonnelKind {
  CUSTOMER
  PARTNER
}

enum CloseRequestDecision {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationKind {
  TASK_DEADLINE_NEAR        // BRD IV.5.6.1 — 4 days before
  TASK_OVERDUE              // BRD IV.5.6.2
  CLOSE_REQUEST_RECEIVED    // KSV / TCHC inbox
  CLOSE_APPROVED            // requester gets confirmation
  CLOSE_REJECTED            // requester gets rejection
  PROJECT_PAUSED_NOTICE
}

enum AuthLogStatus {
  SUCCESS
  FAILURE
}

enum ActivityEntityType {
  PROJECT
  PLAN_ITEM
}

enum CatalogKey {
  projectStatuses
  healthStatuses
  taskStatuses
  riskLevels
  documentCategories
  departments
  projectMemberRoles
}

// ─── Tables ─────────────────────────────────────────────────────────────────

/// Profile row — one per Supabase auth.users entry.
/// `id` matches `auth.users.id` (uuid) so RLS can join via auth.uid().
/// Passwords are owned entirely by Supabase Auth.
model User {
  id              String          @id @db.Uuid
  username        String          @unique
  email           String          @unique
  name            String
  role            UserRole
  functionalTitle FunctionalTitle @default(NORMAL)
  isActive        Boolean         @default(true)
  employeeCode    String          @default("")
  title           String          @default("")
  unit            String          @default("")
  phone           String          @default("")
  monthlyCapacity Int             @default(160)
  avatarColor     String          @default("#0f766e")
  // v3.12 BA (19/05/2026): cờ nhận diện nhân sự đã nghỉ từ HRM. UI highlight
  // đỏ nhạt + badge khi user.isResigned = true.
  isResigned      Boolean         @default(false)
  resignedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  managedProjects     Project[]              @relation("ProjectAdmin")
  createdProjects     Project[]              @relation("ProjectCreator")
  sponsoredProjects   Project[]              @relation("ProjectSponsor")
  memberships         ProjectMember[]
  planItemAssignees   PlanItemAssignee[]
  ownedRisks          ProjectRisk[]
  worklogs            Worklog[]
  decidedWorklogs     Worklog[]              @relation("WorklogDecided")
  raisedDelays        DelayRaise[]
  activityLogs        ActivityLog[]
  monthlyAllocations  MonthlyAllocation[]
  closeRequests       ProjectCloseRequest[]  @relation("CloseRequester")
  ksvDecisions        ProjectCloseRequest[]  @relation("CloseKsv")
  tchcDecisions       ProjectCloseRequest[]  @relation("CloseTchc")
  externalPersonnelCreated  ExternalPersonnel[] @relation("ExtPersonnelCreator")
  externalPersonnelUpdated  ExternalPersonnel[] @relation("ExtPersonnelUpdater")

  @@map("profiles")
}

model Project {
  id                String        @id @default(cuid())
  code              String        @unique
  name              String
  summary           String        @default("")
  sponsor           String        @default("")
  department        String        @default("")
  objective         String        @default("")
  ttkDecisionNumber String        @default("")
  createdById       String        @db.Uuid
  adminId           String        @db.Uuid
  psUserId          String?       @db.Uuid                       // BRD IV.4.1 — Project Sponsor (was inline in personnelInfo)
  projectType       ProjectType   @default(INTERNAL)             // BRD III.1.2.2.1
  startDate         DateTime
  endDate           DateTime
  // v3.12 BA #6 Q1 option (b): cột kickoffDate riêng (giữ startDate cho tương thích).
  // UI Thông tin chung hiển thị Ngày kick off từ cột này; nếu null fallback startDate.
  kickoffDate       DateTime?
  status            ProjectStatus @default(ACTIVE)               // v3.1: was INITIATION/PLANNING/...; now operational
  health            HealthStatus  @default(STABLE)               // v3.1: now auto-derived (job lands in v3.2)
  progress          Int           @default(0)
  currentPhase      String        @default("")
  adjustedPlan      String        @default("")
  riskSummary       String        @default("")
  pausedAt          DateTime?                                    // BRD III.1.2.5 — Tạm đóng timestamp
  closedAt          DateTime?                                    // BRD III.1.2.5 — Đóng timestamp

  // Nested sub-objects → JSONB. See types/domain.ts for shapes.
  // (v3.x: approvalInfo column removed — TCHC creates projects directly,
  // no PENDING→APPROVED flow; see BA decision 12/05/2026.)
  basisInfo     Json @default("{}")
  financialInfo Json @default("{}")
  personnelInfo Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admin     User  @relation("ProjectAdmin", fields: [adminId], references: [id], onDelete: Restrict)
  createdBy User  @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  ps        User? @relation("ProjectSponsor", fields: [psUserId], references: [id], onDelete: SetNull)

  members            ProjectMember[]
  documents          ProjectDocument[]
  monthlyAllocations MonthlyAllocation[]
  risks              ProjectRisk[]
  planItems          PlanItem[]
  worklogs           Worklog[]
  delayRaises        DelayRaise[]
  activityLogs       ActivityLog[]
  closeRequests      ProjectCloseRequest[]
  externalPersonnel  ProjectExternalPersonnel[]

  @@index([adminId])
  @@index([status])
  @@map("projects")
}

model ProjectMember {
  projectId         String
  userId            String  @db.Uuid
  isCoordinator     Boolean @default(false)              // BRD: Điều phối TTK
  roleInProject     String  @default("")                 // BRD IV.5.1.2 — vai trò
  responsibility    String  @default("")                 // BRD IV.5.1.2 — nhiệm vụ
  totalPlannedHours Int     @default(0)                  // BRD IV.5.1.2 — tổng giờ công

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@index([projectId, isCoordinator])
  @@map("project_members")
}

/// One open close-request per project (state: PENDING -> KSV decides -> TCHC decides).
/// History row preserved after a decision; new request opens after rejection.
/// (BA 14/05/2026: TCNL was renamed to TCHC — the second-stage approver is
/// now any user with role = ADMIN_HC, no functional-title overlay needed.)
model ProjectCloseRequest {
  id                String                @id @default(cuid())
  projectId         String
  requestedById     String                @db.Uuid
  requestedAt       DateTime              @default(now())
  note              String                @default("")
  ksvDecision       CloseRequestDecision  @default(PENDING)
  ksvDecidedById    String?               @db.Uuid
  ksvDecidedAt      DateTime?
  ksvRejectReason   String                @default("")
  tchcDecision      CloseRequestDecision  @default(PENDING)
  tchcDecidedById   String?               @db.Uuid
  tchcDecidedAt     DateTime?
  tchcRejectReason  String                @default("")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requester User    @relation("CloseRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  ksv       User?   @relation("CloseKsv", fields: [ksvDecidedById], references: [id], onDelete: SetNull)
  tchc      User?   @relation("CloseTchc", fields: [tchcDecidedById], references: [id], onDelete: SetNull)

  @@index([projectId, ksvDecision, tchcDecision])
  @@map("project_close_requests")
}

model ProjectDocument {
  id             String    @id @default(cuid())
  projectId      String
  title          String
  category       String    @default("")
  documentNumber String    @default("")
  description    String    @default("")
  url            String    @default("")
  // v3.3: Supabase Storage path. When set, the file lives in the qlda-documents
  // bucket and `url` is empty. The two coexist for back-compat: legacy URL-only
  // documents stay readable; new uploads use storagePath.
  storagePath    String    @default("")
  mimeType       String    @default("")
  sizeBytes      Int       @default(0)
  uploadedBy     String    @db.Uuid
  uploadedAt     DateTime  @default(now())
  updatedBy      String?   @db.Uuid
  updatedAt      DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_documents")
}

model MonthlyAllocation {
  projectId String
  memberId  String @db.Uuid
  month     String
  hours     Int    @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member  User    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([projectId, memberId, month])
  @@index([projectId])
  @@index([memberId, month])
  @@map("monthly_allocations")
}

/// BRD IV.5.1.4 — risk register fields.
model ProjectRisk {
  id                 String     @id @default(cuid())
  projectId          String
  title              String                                 // Nhận diện rủi ro
  cause              String     @default("")               // Nguyên nhân
  description        String     @default("")               // Nội dung
  level              RiskLevel  @default(LOW)
  status             RiskStatus @default(OPEN)
  ownerId            String     @db.Uuid                   // Nhân sự khắc phục
  mitigation         String     @default("")               // Giải pháp
  dueDate            DateTime?                             // Hạn xử lý
  resolutionResult   String     @default("")               // Kết quả thực hiện
  resolutionProgress Int        @default(0)                // Tiến độ xử lý (0-100)
  nextPlan           String     @default("")               // Kế hoạch tiếp theo
  notes              String     @default("")               // Ghi chú
  lastUpdated        DateTime   @default(now())            // Thời gian cập nhật
  createdAt          DateTime   @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User    @relation(fields: [ownerId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@map("project_risks")
}

/// BRD IV.2.7 — Customer / Partner personnel catalog. Reusable across projects.
/// Replaces the old per-project JSONB personnelInfo.customerMembers / partners arrays.
model ExternalPersonnel {
  id            String                  @id @default(cuid())
  kind          ExternalPersonnelKind
  fullName      String
  employeeCode  String                  @default("")
  title         String                  @default("")
  unit          String                  @default("")
  email         String                  @default("")
  phone         String                  @default("")
  isActive      Boolean                 @default(true)
  createdById   String                  @db.Uuid
  createdAt     DateTime                @default(now())
  updatedById   String?                 @db.Uuid
  updatedAt     DateTime                @updatedAt

  createdBy User                          @relation("ExtPersonnelCreator", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User?                         @relation("ExtPersonnelUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  projects  ProjectExternalPersonnel[]

  @@index([kind, isActive])
  @@index([email])
  @@map("external_personnel")
}

/// Per-project assignment of an ExternalPersonnel record. Carries project-specific
/// fields (role, responsibility, allocated hours).
model ProjectExternalPersonnel {
  projectId            String
  externalPersonnelId  String
  roleInProject        String   @default("")
  responsibility       String   @default("")
  totalPlannedHours    Int      @default(0)
  createdAt            DateTime @default(now())

  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  externalPersonnel ExternalPersonnel @relation(fields: [externalPersonnelId], references: [id], onDelete: Cascade)

  @@id([projectId, externalPersonnelId])
  @@index([projectId])
  @@map("project_external_personnel")
}

model PlanItem {
  id                String         @id @default(cuid())
  projectId         String
  parentId          String?
  name              String
  workType          WorkType       @default(SUBTASK)
  ownerId           String         @db.Uuid
  assigneeId        String         @db.Uuid
  status            PlanTaskStatus @default(NOT_STARTED)
  baselineStartDate DateTime
  baselineEndDate   DateTime
  startDate         DateTime
  endDate           DateTime
  progress          Int            @default(0)
  plannedHours      Int            @default(0)
  actualHours       Int            @default(0)
  monthAllocations  Json           @default("[]")
  dependencyNote    String         @default("")
  deliverable       String         @default("")
  replanRequested   Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      PlanItem?          @relation("PlanItemHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    PlanItem[]         @relation("PlanItemHierarchy")
  assignees   PlanItemAssignee[]
  worklogs    Worklog[]
  delayRaises DelayRaise[]

  @@index([projectId])
  @@index([parentId])
  @@map("plan_items")
}

model PlanItemAssignee {
  planItemId String
  userId     String @db.Uuid
  planItem   PlanItem @relation(fields: [planItemId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([planItemId, userId])
  @@index([userId])
  @@map("plan_item_assignees")
}

model Worklog {
  id           String   @id @default(cuid())
  taskId       String
  projectId    String
  memberId     String   @db.Uuid
  date         DateTime
  hours        Int      @default(0)
  progressNote String   @default("")
  createdAt    DateTime @default(now())

  // v3.12 BA #7 (19/05/2026): worklog approval workflow.
  // Worklog mới mặc định PENDING; chỉ APPROVED mới cộng vào task.actualHours.
  // PM dự án + điều phối + PMO có quyền duyệt/từ chối. Không tự duyệt worklog
  // của chính mình.
  status         WorklogStatus @default(PENDING)
  decidedById    String?       @db.Uuid
  decidedAt      DateTime?
  rejectReason   String        @default("")

  task        PlanItem @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member      User     @relation(fields: [memberId], references: [id], onDelete: Restrict)
  decidedBy   User?    @relation("WorklogDecided", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([projectId, memberId])
  @@map("worklogs")
}

model DelayRaise {
  id              String           @id @default(cuid())
  projectId       String
  taskId          String
  requesterId     String           @db.Uuid
  requestedAt     DateTime         @default(now())
  reason          String           @default("")
  impact          String           @default("")
  status          DelayRaiseStatus @default(OPEN)
  managerResponse String           @default("")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      PlanItem @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requester User     @relation(fields: [requesterId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([taskId])
  @@map("delay_raises")
}

model ActivityLog {
  id         String             @id @default(cuid())
  projectId  String
  userId     String             @db.Uuid
  action     ActivityLogAction
  entityType ActivityEntityType
  entityId   String
  entityName String             @default("")
  changes    Json               @default("[]")
  timestamp  DateTime           @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([projectId, timestamp])
  @@map("activity_logs")
}

model CatalogGroup {
  key    CatalogKey @id
  values Json       @default("[]")

  @@map("catalog_groups")
}

/// v3.2 — in-app notifications. Push from BE on close-flow events and deadline alerts.
model Notification {
  id        String           @id @default(cuid())
  userId    String           @db.Uuid
  kind      NotificationKind
  title     String           @default("")
  body      String           @default("")
  payload   Json             @default("{}")  // structured data for the FE (projectId, taskId, requestId, etc.)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

/// v3.2 — login/logout audit per BRD VIII.3 (IP, time, login state).
/// userId is nullable for failed logins where we don't recognise the email.
model AuthLog {
  id         String        @id @default(cuid())
  userId     String?       @db.Uuid
  email      String        @default("")
  ip         String        @default("")
  userAgent  String        @default("")
  status     AuthLogStatus
  reason     String        @default("")
  createdAt  DateTime      @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("auth_logs")
}
