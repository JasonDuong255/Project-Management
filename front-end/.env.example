# In dev, leave VITE_API_URL as '/api' — vite.config.ts proxies it to the
# backend on http://localhost:4000. In production, set this to the public URL
# of your deployed backend, e.g. https://api.qlda.example.com/api.
VITE_API_URL=/api

# Supabase project URL and anon key. Must match the backend's SUPABASE_URL
# and SUPABASE_ANON_KEY (i.e. FE and BE talk to the same Supabase project).
# Find these in: Supabase dashboard → Project Settings → API.
#
# DO NOT put SUPABASE_SERVICE_ROLE_KEY or SUPABASE_JWT_SECRET here — those go
# on the backend only.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>
